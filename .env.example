# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── AI providers ──────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_key_here
OPENAI_API_KEY=your_openai_key_here
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key_here

# Model defaults
AI_QUIZ_MODEL=claude-haiku-4-5
AI_GRADE_MODEL=gpt-5.4-mini

# ── Upstash Redis (rate limiting) ─────────────────────────────────────
KV_REST_API_URL=https://your-instance.upstash.io
KV_REST_API_TOKEN=your_upstash_token_here
KV_REST_API_READ_ONLY_TOKEN=your_upstash_readonly_token_here
KV_URL=rediss://default:token@your-instance.upstash.io:6379
REDIS_URL=rediss://default:token@your-instance.upstash.io:6379

# ── Resend (transactional email) ──────────────────────────────────────
RESEND_API_KEY=your_resend_key_here
EMAIL_FROM=Jisr <noreply@your-domain.com>

# ── Public landing-page contact info ──────────────────────────────────
NEXT_PUBLIC_CONTACT_WHATSAPP=212XXXXXXXXX
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=+212 XXX-XXX-XXX
NEXT_PUBLIC_CONTACT_EMAIL=contact@your-domain.com
