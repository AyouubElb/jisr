# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# docs (internal architecture notes, not for public repo)
/docs

# supabase: track migrations + schema, ignore local-only state + secrets
/supabase/.branches/
/supabase/.temp/
/supabase/seed.sql
/supabase/.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin

# Claude Code local settings/session state (per-developer)
/.claude

# Dev scripts (load tests, one-off tooling — not app code)
/scripts

# CLT experiment pages (local testing only)
/src/app/(instructor)/instructor/clt

# Load-test mock endpoint (kept local for re-testing, never deployed)
/src/app/api/load-test
